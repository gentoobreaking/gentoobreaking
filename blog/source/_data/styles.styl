// 文章卡片圓角化
.post-block {
  border-radius: 12px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  margin-bottom: 24px;
  padding: 40px;
}

// 側邊欄圓角化
.sidebar-inner {
  border-radius: 12px;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}

// 標題加粗
.post-title {
  font-weight: 700;
  color: #1e293b;
}

// 頂部導覽列優化
.header-inner {
  border-radius: 0 0 12px 12px;
}

// 按鈕美化
.btn {
  border-radius: 6px;
  transition: all 0.3s ease;
}
